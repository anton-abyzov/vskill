exports[`GroupHeader (0698 T-008) > matches stored snapshot (regression guard) 1`] = `"<div data-vskill-group-header="AVAILABLE" role="heading" aria-level="3" class="vskill-group-header select-none" style="position:sticky;top:0;z-index:4;backdrop-filter:saturate(1.4) blur(10px);-webkit-backdrop-filter:saturate(1.4) blur(10px);background:color-mix(in oklch, var(--color-accent, #2f6f8f) 8%, var(--color-paper, #fff));border-left:3px solid var(--color-accent, #2f6f8f);border-bottom:1px solid var(--border-subtle, rgba(128,128,128,0.2));padding:7px 10px 7px 9px;font-family:var(--font-serif, ui-serif);font-size:13px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-primary);display:flex;align-items:center;gap:8px;width:100%;cursor:default;border:none;text-align:left"><span class="vskill-group-header-name">AVAILABLE</span><span class="vskill-group-header-count tabular-nums" style="font-family:var(--font-mono);font-size:11px;font-weight:500;color:var(--text-secondary);letter-spacing:0;text-transform:none">(12)</span></div>"`;
